# Copy to .env and fill in your values
# ─────────────────────────────────────

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Model name (required). Examples: gpt-5.4-mini, gpt-4o, gpt-4-turbo
LLM_MODEL=gpt-5.4-mini

# ── Anthropic (optional — only needed for --providers anthropic) ──────────────
ANTHROPIC_API_KEY=sk-ant-...
# Model for Anthropic provider. Default: claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Kaggle (optional — only needed for automatic dataset download) ────────────
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── Provider ─────────────────────────────────────────────────────────────────
# Default LLM provider. Override per-run with --providers flag.
LLM_PROVIDER=openai

# ── Self-repair ───────────────────────────────────────────────────────────────
# Max repair attempts when generated SQL fails EXPLAIN validation (0 = disabled)
MAX_REPAIR_RETRIES=2

# ── Coverage scoring ──────────────────────────────────────────────────────────
# If recall=1.0 and returned rows > expected * this threshold, call LLM-as-judge
COVERAGE_SUPERSET_THRESHOLD=1.5

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://aistrike:aistrike@localhost:5433/cloudtrail

# ── Data paths ────────────────────────────────────────────────────────────────
CSV_PATH=data/nineteenFeaturesDf.csv
HYPOTHESES_PATH=data/hypotheses.json
HYPOTHESES_OUTCOMES_PATH=data/hypotheses_outcomes.json
